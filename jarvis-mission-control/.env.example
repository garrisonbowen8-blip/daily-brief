# Copy to .env.local (gitignored) and fill in. Never commit real keys.

# ── Voice (ElevenLabs) — without these the app falls back to browser TTS ──
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# ── Google (Gmail / Calendar / Drive) ──
# By default the app reuses ../config.json from the daily-brief setup
# (scripts/setup.sh + npm run auth). Override the path here if needed.
DAILY_BRIEF_CONFIG=
DAILY_BRIEF_MY_DATA=

# ── Buddy Check (Supabase) — server-side only, never expose the service key ──
SUPABASE_URL=https://woqtddskdbwmoygyeucg.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# ── Porter Metrics (remote MCP) ──
PORTER_MCP_URL=
PORTER_MCP_TOKEN=
PORTER_TOOL=
PORTER_QUERY=

# ── Obsidian — absolute path to your vault folder ──
OBSIDIAN_VAULT_PATH=

# ── Future connectors (tiles are stubbed until these exist) ──
MS365_TOKEN=
CANVA_TOKEN=
INDEED_TOKEN=
CREDIT_KARMA_TOKEN=
PUBMED_API_KEY=
